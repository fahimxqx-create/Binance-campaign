<script>
function tick(){
  const now=new Date(new Date().toLocaleString("en-US",{timeZone:"Asia/Dhaka"}));
  const h=String(now.getHours()).padStart(2,'0');
  const m=String(now.getMinutes()).padStart(2,'0');
  const s=String(now.getSeconds()).padStart(2,'0');
  const ampm=now.getHours()>=12?'PM':'AM';
  document.getElementById('clock').innerHTML=
    `${h}<span class="colon">:</span>${m}<span class="colon">:</span>${s}`;
  document.getElementById('ampm').textContent=ampm+' (BST UTC+6)';

  const months=['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন',
                'জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর'];
  const days=['রবিবার','সোমবার','মঙ্গলবার','বুধবার','বৃহস্পতিবার','শুক্রবার','শনিবার'];
  document.getElementById('dateNum').textContent=
    `${now.getDate()} ${months[now.getMonth()]}`;
  document.getElementById('dateInfo').textContent=
    `${now.getFullYear()} · ${days[now.getDay()]}`;
}
tick();setInterval(tick,1000);

// Prevent Ctrl+S, Ctrl+U
document.addEventListener('keydown',function(e){
  if((e.ctrlKey||e.metaKey)&&['s','u','p'].includes(e.key.toLowerCase()))e.preventDefault();
});
</script>
