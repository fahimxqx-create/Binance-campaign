<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Binance Campaign BD</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#F0B90B;
  --gold-light:#FFD94A;
  --gold-dark:#c8960a;
  --bg:#07080a;
  --card:#101215;
  --card2:#161820;
  --border:rgba(240,185,11,0.15);
  --border2:rgba(240,185,11,0.28);
  --text:#e6ddc8;
  --muted:#7a7060;
  --white:#ffffff;
}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  min-height:100vh;
  overflow-x:hidden;
}

/* ── BG EFFECTS ── */
.bg-glow{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 35% at 15% 8%, rgba(240,185,11,0.09) 0%, transparent 65%),
    radial-gradient(ellipse 45% 55% at 85% 92%, rgba(240,185,11,0.06) 0%, transparent 65%);
}
.bg-grid{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    linear-gradient(rgba(240,185,11,0.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(240,185,11,0.035) 1px,transparent 1px);
  background-size:48px 48px;
}

/* ── LAYOUT ── */
.wrap{position:relative;z-index:1;max-width:820px;margin:0 auto;padding:0 16px 70px}

/* ── HERO ── */
.hero{
  text-align:center;padding:56px 0 28px;
  animation:fadeDown .8s ease both;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(240,185,11,0.1);
  border:1px solid rgba(240,185,11,0.4);
  color:var(--gold-light);
  font-size:11px;letter-spacing:2.5px;
  padding:6px 20px;border-radius:999px;
  margin-bottom:24px;text-transform:uppercase;
  font-weight:600;
}
.hero-title{
  font-family:'Syne',sans-serif;
  font-size:clamp(2.1rem,7vw,3.8rem);
  font-weight:800;line-height:1.08;
  background:linear-gradient(140deg,#FFD94A 0%,#F0B90B 50%,#a87200 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:14px;
}
.hero-sub{
  color:var(--muted);font-size:.95rem;
  max-width:420px;margin:0 auto;line-height:1.75;
}
.hero-divider{
  width:80px;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  margin:22px auto 0;
}

/* ── SECTION HEADER (fixed!) ── */
.sec-head{
  display:flex;align-items:center;gap:12px;
  margin-bottom:18px;
}
.sec-head-icon{
  width:36px;height:36px;border-radius:10px;
  background:rgba(240,185,11,0.12);
  border:1px solid rgba(240,185,11,0.25);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
}
.sec-head-text{
  font-family:'Syne',sans-serif;
  font-size:1rem;font-weight:700;
  color:var(--gold-light);letter-spacing:.5px;
}
.sec-head-line{flex:1;height:1px;background:var(--border)}

/* ── CARDS ── */
.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:18px;
  padding:24px 22px;
  margin-bottom:18px;
  position:relative;overflow:hidden;
  animation:fadeUp .6s ease both;
}
.card::before{
  content:'';position:absolute;
  top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}

/* ── TIME ROW ── */
.time-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:32px 0 18px;animation:fadeUp .6s .15s ease both}
@media(max-width:480px){.time-row{grid-template-columns:1fr}}
.time-box{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:22px 18px;text-align:center;
  position:relative;overflow:hidden;
}
.time-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.time-box-label{
  font-size:11px;letter-spacing:1.5px;
  color:var(--gold);text-transform:uppercase;
  font-weight:600;margin-bottom:10px;
}
.time-box-val{
  font-family:'Syne',sans-serif;
  font-size:clamp(1.6rem,4vw,2.3rem);
  font-weight:800;color:#fff;letter-spacing:3px;
}
.time-box-sub{font-size:.72rem;color:var(--muted);margin-top:5px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.colon{animation:blink 1s infinite}

/* ── LINK BUTTONS ── */
.lbtn{
  display:flex;align-items:center;gap:14px;
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:12px;padding:15px 18px;
  text-decoration:none;color:var(--text);
  transition:all .22s ease;margin-bottom:11px;
}
.lbtn:hover{
  border-color:var(--gold);
  background:linear-gradient(135deg,#191700,#1f1c00);
  transform:translateY(-2px);
  box-shadow:0 8px 28px rgba(240,185,11,0.13);
}
.lbtn-icon{
  width:42px;height:42px;border-radius:11px;
  background:rgba(240,185,11,0.1);
  border:1px solid rgba(240,185,11,0.2);
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;flex-shrink:0;
}
.lbtn-text strong{display:block;font-size:.88rem;font-weight:700;color:#fff;margin-bottom:2px}
.lbtn-text span{font-size:.78rem;color:var(--muted)}
.lbtn-arrow{margin-left:auto;color:var(--gold);font-size:1.2rem;flex-shrink:0}

/* ── STATS ROW ── */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
@media(max-width:480px){.stats-row{grid-template-columns:1fr 1fr}}
.stat-box{
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:12px;padding:16px 12px;text-align:center;
}
.stat-num{
  font-family:'Syne',sans-serif;
  font-size:1.7rem;font-weight:800;
  color:var(--gold-light);
}
.stat-lbl{font-size:.75rem;color:var(--muted);margin-top:4px;line-height:1.4}

/* ── VIDEO ── */
.vid-outer{
  border-radius:14px;overflow:hidden;
  border:1px solid var(--border);
  background:#000;
  user-select:none;-webkit-user-select:none;
  position:relative;
}
.vid-placeholder{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:200px;padding:32px 20px;text-align:center;
  background:linear-gradient(135deg,#0e1014,#13160f);
}
.vid-play-icon{
  width:70px;height:70px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold-dark));
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;margin-bottom:16px;
  box-shadow:0 0 40px rgba(240,185,11,0.35);
  cursor:pointer;transition:transform .2s;
}
.vid-play-icon:hover{transform:scale(1.08)}
.vid-placeholder p{color:var(--muted);font-size:.88rem;line-height:1.7;max-width:320px}
.vid-lock{
  font-size:.73rem;color:var(--muted);
  margin-top:10px;
  display:flex;align-items:center;gap:6px;
}

/* ── TICKER ── */
.ticker-wrap{
  overflow:hidden;background:rgba(240,185,11,0.06);
  border:1px solid var(--border);border-radius:10px;
  padding:10px 0;margin-bottom:18px;
  position:relative;
}
.ticker-wrap::before,.ticker-wrap::after{
  content:'';position:absolute;top:0;bottom:0;width:40px;z-index:2;
}
.ticker-wrap::before{left:0;background:linear-gradient(90deg,var(--card),transparent)}
.ticker-wrap::after{right:0;background:linear-gradient(-90deg,var(--card),transparent)}
.ticker-track{
  display:flex;gap:0;
  animation:ticker 22s linear infinite;
  white-space:nowrap;
}
.ticker-item{
  padding:0 28px;font-size:.8rem;
  color:var(--gold-light);font-weight:600;
  letter-spacing:.5px;
}
.ticker-dot{color:var(--muted)}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── FEATURE LIST ── */
.feat-list{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.feat-list li{
  display:flex;align-items:flex-start;gap:12px;
  background:rgba(240,185,11,0.05);
  border:1px solid rgba(240,185,11,0.1);
  border-radius:10px;padding:13px 16px;
  font-size:.92rem;line-height:1.65;
}
.feat-dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--gold);flex-shrink:0;margin-top:7px;
}

/* ── SUPPORT BOX ── */
.support-box{
  background:linear-gradient(135deg,rgba(240,185,11,0.07),rgba(240,185,11,0.02));
  border:1px solid rgba(240,185,11,0.22);
  border-radius:14px;padding:20px 22px;
  font-size:.9rem;line-height:1.8;
}
.support-box strong{color:var(--gold-light)}

/* ── DIVIDER ── */
.divider{
  height:1px;
  background:linear-gradient(90deg,transparent,var(--border2),transparent);
  margin:22px 0;
}

/* ── ONLINE BADGE ── */
.online-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(0,200,80,0.1);border:1px solid rgba(0,200,80,0.3);
  color:#4ade80;font-size:.78rem;font-weight:600;
  padding:5px 14px;border-radius:999px;margin-bottom:16px;
}
.online-dot{
  width:8px;height:8px;border-radius:50%;
  background:#4ade80;
  animation:pulse-green 1.4s infinite;
}
@keyframes pulse-green{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,.6)}70%{box-shadow:0 0 0 7px rgba(74,222,128,0)}}

/* ── FOOTER ── */
.footer{
  text-align:center;
  font-size:.78rem;color:var(--muted);
  padding-top:22px;border-top:1px solid var(--border);
  line-height:1.8;
}
.footer strong{color:var(--gold)}

/* ── ANIMATIONS ── */
@keyframes fadeDown{from{opacity:0;transform:translateY(-22px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
.d1{animation-delay:.2s}.d2{animation-delay:.32s}.d3{animation-delay:.44s}.d4{animation-delay:.55s}
</style>
</head>
